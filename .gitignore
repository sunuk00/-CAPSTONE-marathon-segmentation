# Python bytecode and cache
__pycache__/
*.py[cod]
*$py.class

# Build and packaging artifacts
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/
dev1/

# Conda environments and local env files
.conda/
conda-meta/
.env
.env.*
.python-version

# Jupyter
.ipynb_checkpoints/

# Test and coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Project outputs (models, predictions, logs)
# Default: ignore everything under outputs
outputs/**

# Keep only experiment documentation and selected sample predictions
!outputs/
!outputs/unet_baseline/
!outputs/unet_bce_iou/
!outputs/unet_baseline/README.md

# Allow prediction folders to be visible, but ignore contents by default
!outputs/unet_baseline/test_predictions/
!outputs/unet_bce_iou/test_predictions/
outputs/unet_baseline/test_predictions/*
outputs/unet_bce_iou/test_predictions/*

# Keep only first 5 samples (current naming order)
!outputs/unet_baseline/test_predictions/038_pred.png
!outputs/unet_baseline/test_predictions/039_pred.png
!outputs/unet_baseline/test_predictions/040_pred.png
!outputs/unet_baseline/test_predictions/041_pred.png
!outputs/unet_baseline/test_predictions/042_pred.png
!outputs/unet_bce_iou/test_predictions/038_pred.png
!outputs/unet_bce_iou/test_predictions/039_pred.png
!outputs/unet_bce_iou/test_predictions/040_pred.png
!outputs/unet_bce_iou/test_predictions/041_pred.png
!outputs/unet_bce_iou/test_predictions/042_pred.png

