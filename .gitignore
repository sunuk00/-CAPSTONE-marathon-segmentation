# Python bytecode and cache
__pycache__/
*.py[cod]
*$py.class

# Build and packaging artifacts
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/
dev1/

# Conda environments and local env files
.conda/
conda-meta/
.env
.env.*
.python-version

# Jupyter
.ipynb_checkpoints/

# Test and coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Project outputs (models, predictions, logs)
# Default: ignore everything under outputs
outputs/**

# Keep only experiment documentation and selected sample predictions
!outputs/
!outputs/unet_baseline/
!outputs/unet_baseline/README.md

# Allow experiment subfolders to be visible, but ignore their contents by default
!outputs/unet_baseline/*/
outputs/unet_baseline/*/*

# Keep only first 3 samples (current naming order) from each experiment folder
!outputs/unet_baseline/*/038_pred.png
!outputs/unet_baseline/*/039_pred.png
!outputs/unet_baseline/*/040_pred.png

# Optional local data folders (uncomment if needed)
# data/
